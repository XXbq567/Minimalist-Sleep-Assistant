<Window x:Class="TimerAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="极简睡眠" Height="420" Width="360" 
        Icon="app.ico" 
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="White" FontFamily="Segoe UI, Microsoft YaHei">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="45"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
            <RadioButton x:Name="RbSleep" Content="睡眠" IsChecked="True" FontSize="16" Margin="0,0,30,0" Foreground="#333"/>
            <RadioButton x:Name="RbShutdown" Content="关机" FontSize="16" Foreground="#333"/>
        </StackPanel>

        <StackPanel Grid.Row="1" x:Name="PanelInput" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBox x:Name="TxtHours" Text="0" PreviewTextInput="NumberValidation" TextChanged="TimeInput_TextChanged" GotFocus="Txt_GotFocus" LostFocus="Txt_LostFocus"/>
                <TextBlock Text="时" FontSize="20" VerticalAlignment="Center" Margin="10,0,20,0" Foreground="#555"/>
                <TextBox x:Name="TxtMinutes" Text="0" PreviewTextInput="NumberValidation" TextChanged="TimeInput_TextChanged" GotFocus="Txt_GotFocus" LostFocus="Txt_LostFocus"/>
                <TextBlock Text="分" FontSize="20" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button Content="30分钟" Click="QuickSet_Click" Tag="30" Margin="5" Padding="10,5" Background="#E0F2F1" Foreground="#00695C" BorderThickness="0" Cursor="Hand"/>
                <Button Content="60分钟" Click="QuickSet_Click" Tag="60" Margin="5" Padding="10,5" Background="#E0F2F1" Foreground="#00695C" BorderThickness="0" Cursor="Hand"/>
                <Button Content="2小时" Click="QuickSet_Click" Tag="120" Margin="5" Padding="10,5" Background="#E0F2F1" Foreground="#00695C" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="2" x:Name="TxtCountdown" Text="00:00:00" FontSize="56" FontWeight="Bold" 
                   Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,30,0,20"/>

        <Button Grid.Row="4" x:Name="BtnAction" Content="开始" Height="50" FontSize="20" FontWeight="Bold" 
                Foreground="White" Background="{StaticResource PrimaryColor}" BorderThickness="0" 
                Cursor="Hand" Click="BtnAction_Click" IsEnabled="False"/>
    </Grid>
</Window>