<Window x:Class="TimerAssistant.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="操作确认" Height="220" Width="320" 
        Icon="app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" 
        Topmost="True" Background="White" FontFamily="Segoe UI, Microsoft YaHei">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock x:Name="TxtMessage" Text="到时间了，执行[操作]吗？" 
                       TextAlignment="Center" FontSize="18" Foreground="#333" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock x:Name="TxtCountdown" Text="30 s 自动确认" 
                       FontSize="13" Foreground="#999" 
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="BtnConfirm" Content="确认" Height="40" FontSize="16" 
                    Background="{StaticResource PrimaryColor}" Foreground="White" BorderThickness="0" Click="BtnConfirm_Click"/>
            <Button Grid.Column="2" x:Name="BtnCancel" Content="取消" Height="40" FontSize="16" 
                    Background="#ddd" Foreground="#333" BorderThickness="0" Click="BtnCancel_Click"/>
        </Grid>
    </Grid>
</Window>